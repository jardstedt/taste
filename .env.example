# Virtuals ACP (optional — required for agent protocol integration)
ACP_WALLET_PRIVATE_KEY=          # Dev wallet private key (no 0x prefix)
ACP_AGENT_WALLET_ADDRESS=        # Agent smart wallet address
ACP_SESSION_ENTITY_KEY_ID=       # Entity ID from GAME console
GAME_API_KEY=                    # From console.game.virtuals.io

# Server
PORT=3001
JWT_SECRET=                      # Min 16 chars. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_EMAIL=admin@taste.local    # Initial admin expert email
ADMIN_PASSWORD=                  # Min 8 chars. Initial admin password (hashed on first run)

# Database
DB_PATH=./data/taste.db

# Security
EMAIL_ENCRYPTION_KEY=            # 32-byte hex key. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FILE_SIGNING_SECRET=             # Optional. Separate secret for signed file URLs. Falls back to JWT_SECRET if not set.
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development             # development | production

# Push Notifications (Web Push VAPID)
# Generate keypair: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@taste.xyz

# MCP Server (optional — x402 payment-gated MCP tools)
MCP_PORT=3002                    # Port for MCP Streamable HTTP server
MCP_WALLET_ADDRESS=              # 0x... Base wallet to receive USDC payments
MCP_FACILITATOR_URL=https://x402.org/facilitator  # x402 payment facilitator
MCP_NETWORK=base                 # base | base-sepolia
